# App
APP_NAME=Voltvista Electric
BASE_URL=http://127.0.0.1:8000
DEFAULT_LANG=es

# Business placeholders (pon tus datos reales)
BUSINESS_NAME=VoltVista
BUSINESS_PHONE=+1XXXXXXXXXX
BUSINESS_SMS=+1XXXXXXXXXX
BUSINESS_WHATSAPP=+1XXXXXXXXXX
BUSINESS_EMAIL=your@email.com
BUSINESS_CITY=Orlando, FL
BUSINESS_SERVICE_AREA=Orlando, Kissimmee, Winter Park, Lake Buena Vista, Davenport
BUSINESS_ADDRESS=
BUSINESS_STATE=FL
BUSINESS_ZIP=
BUSINESS_LAT=0.0
BUSINESS_LNG=0.0
BUSINESS_HOURS=Mo-Fr 08:00-18:00
BUSINESS_URL=https://voltvistaelectric.com
BUSINESS_LOGO_URL=https://voltvistaelectric.com/static/img/logo.png
INSTAGRAM_URL=https://www.instagram.com/yourprofile/

# Database
SQLITE_PATH=./voltvista.db

# Email (opcional). Si no lo configuras, igual guarda en SQLite.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO_OWNER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_DEPOSIT_AMOUNT=99.00

# PayPal (REST API)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox   # sandbox | live
PAYPAL_DEPOSIT_AMOUNT=99.00
PAYPAL_CURRENCY=USD

# Upload limits (MB)
MAX_UPLOAD_MB=8

# Tracking (Google Analytics 4 / Google Ads)
GA4_ID=
GADS_ID=
